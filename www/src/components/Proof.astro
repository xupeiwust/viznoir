---
const stats = [
  { value: '22', label: 'MCP Tools' },
  { value: '1489+', label: 'Tests' },
  { value: '10', label: 'Domains' },
  { value: '97%', label: 'Coverage' },
];

const layers = [
  {
    name: 'MCP Server',
    items: '22 tools · 12 resources · 4 prompts',
    desc: 'FastMCP native integration',
  },
  {
    name: 'VTK Engine',
    items: 'readers · filters · renderer · camera',
    desc: 'EGL/OSMesa headless · cinematic lighting · PBR',
  },
  {
    name: 'Physics Layer',
    items: 'topology · context · guard',
    desc: 'Vortex detection · stagnation points · BC parsing',
  },
  {
    name: 'Animation',
    items: '7 presets · 17 easings · transitions',
    desc: 'Physics-driven · timeline · compositor · video',
  },
  {
    name: 'Output',
    items: 'PNG · WebP · MP4 · GLTF · LaTeX',
    desc: '50+ input formats via VTK + meshio',
  },
];
---

<section class="relative py-24">
  <div class="section-divider mb-24"></div>
  <div class="max-w-6xl mx-auto px-6">

    <!-- Stats row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20 fade-up">
      {stats.map((s) => (
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-extrabold gradient-text font-mono mb-1">
            {s.value}
          </div>
          <div class="text-sm font-medium text-text-secondary">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Architecture layers -->
    <div class="fade-up">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">Architecture</span>
        </h2>
      </div>

      <div class="max-w-3xl mx-auto space-y-2">
        {layers.map((layer, i) => (
          <div class={`rounded-xl border border-border/50 p-4 flex items-center gap-4 ${i === 0 ? 'bg-accent/5 border-accent/20' : 'bg-secondary/30'}`}>
            <div class="shrink-0 w-8 text-center">
              <span class="text-xs font-mono text-text-secondary/30">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-0.5">
                <span class={`text-sm font-semibold ${i === 0 ? 'text-accent' : 'text-text-primary'}`}>{layer.name}</span>
                <span class="text-[10px] font-mono text-text-secondary/40">{layer.items}</span>
              </div>
              <p class="text-xs text-text-secondary/50">{layer.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
