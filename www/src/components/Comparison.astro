---
const competitors = [
  { name: 'parapilot', highlight: true, tools: 18, tests: 748, bar: 100 },
  { name: 'LLNL/paraview_mcp', highlight: false, tools: 23, tests: 0, bar: 28, note: 'GUI-attached, no tests' },
  { name: 'Kitware/vtk-mcp', highlight: false, tools: 3, tests: 0, bar: 12, note: 'Docs search only' },
  { name: 'FreeCAD MCP (6+)', highlight: false, tools: 5, tests: 0, bar: 18, note: 'CAD only, no FEM post' },
];

const features = [
  { label: 'Headless rendering', ours: true, others: false },
  { label: 'Test coverage', ours: '748', others: '0' },
  { label: 'File formats', ours: '50+', others: '0–5' },
  { label: 'GPU acceleration', ours: true, others: false },
  { label: 'Docker support', ours: true, others: false },
  { label: 'meshio + trimesh', ours: true, others: false },
];
---

<section class="relative py-28">
  <div class="section-divider mb-28"></div>
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        COMPARISON
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        <span class="gradient-text-white">Why parapilot</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start fade-up">
      <!-- Bar chart -->
      <div class="space-y-5">
        <p class="text-xs font-mono text-text-secondary/50 uppercase tracking-wider mb-2">
          Tool completeness score
        </p>
        {competitors.map((c) => (
          <div>
            <div class="flex items-center gap-3">
              <span class={`w-36 text-sm font-mono truncate text-right ${c.highlight ? 'text-accent font-semibold' : 'text-text-secondary/60'}`}>
                {c.name}
              </span>
              <div class="flex-1 h-9 bg-tertiary rounded-lg overflow-hidden border border-border/50">
                <div
                  class={`bar-fill h-full rounded-lg flex items-center justify-end pr-3 ${c.highlight ? 'bg-gradient-to-r from-accent/60 to-accent/90' : 'bg-border/60'}`}
                  style={`width: ${c.bar}%`}
                >
                  {c.bar >= 25 && (
                    <span class={`text-xs font-mono ${c.highlight ? 'text-primary font-semibold' : 'text-text-secondary/60'}`}>
                      {c.tools} tools &middot; {c.tests} tests
                    </span>
                  )}
                </div>
              </div>
            </div>
            {c.note && (
              <p class="text-xs text-text-secondary/30 ml-[9.5rem] mt-1">{c.note}</p>
            )}
          </div>
        ))}
      </div>

      <!-- Feature table -->
      <div class="rounded-2xl border border-border overflow-hidden">
        <div class="grid grid-cols-3 bg-secondary text-xs font-mono uppercase tracking-wider text-text-secondary/60">
          <div class="px-5 py-3 border-r border-border/50">Feature</div>
          <div class="px-5 py-3 border-r border-border/50 text-center text-accent">parapilot</div>
          <div class="px-5 py-3 text-center">Others</div>
        </div>
        {features.map((f, i) => (
          <div class={`grid grid-cols-3 text-sm ${i % 2 === 0 ? 'bg-tertiary/50' : 'bg-secondary/30'}`}>
            <div class="px-5 py-3 border-r border-border/30 text-text-secondary/70">{f.label}</div>
            <div class="px-5 py-3 border-r border-border/30 text-center">
              {typeof f.ours === 'boolean' ? (
                <span class="text-[#28c840]">&#10003;</span>
              ) : (
                <span class="text-accent font-mono font-semibold">{f.ours}</span>
              )}
            </div>
            <div class="px-5 py-3 text-center">
              {typeof f.others === 'boolean' ? (
                <span class="text-red-400/60">&#10007;</span>
              ) : (
                <span class="text-text-secondary/30 font-mono">{f.others}</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
