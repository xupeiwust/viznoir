---
const stats = [
  { value: '18', label: 'MCP Tools', detail: 'render, slice, contour, clip, streamlines, cinematic, compare, batch, probe, preview_3d ...' },
  { value: '11', label: 'Resources', detail: 'formats, filters, colormaps, cameras, cinematic, pipelines ...' },
  { value: '1048', label: 'Tests', detail: 'pytest CI — 99% coverage, runs on every PR' },
  { value: '50+', label: 'Formats', detail: 'OpenFOAM, VTK, STL, CGNS, Abaqus, Gmsh ...' },
];
---

<section class="relative py-28">
  <div class="section-divider mb-28"></div>
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 fade-up">
      {stats.map((s) => (
        <div class="text-center group">
          <div class="text-5xl sm:text-6xl font-extrabold gradient-text font-mono mb-2 group-hover:scale-105 transition-transform">
            {s.value}
          </div>
          <div class="text-lg font-semibold text-text-primary mb-1">{s.label}</div>
          <div class="text-xs text-text-secondary/50 font-mono leading-relaxed">{s.detail}</div>
        </div>
      ))}
    </div>
  </div>
</section>
