---
const images = [
  {
    src: '/viznoir/showcase/drivaerml_cp.webp',
    alt: 'DrivAerML automotive CFD pressure coefficient',
    label: 'Automotive CFD',
  },
  {
    src: '/viznoir/showcase/ct_head_contour.webp',
    alt: 'CT skull bone isosurface',
    label: 'Medical CT',
  },
  {
    src: '/viznoir/showcase/streamlines.webp',
    alt: 'Carotid artery blood flow streamlines',
    label: 'Blood Flow',
  },
  {
    src: '/viznoir/showcase/office_flow.webp',
    alt: 'Office HVAC airflow streamlines',
    label: 'HVAC Flow',
  },
  {
    src: '/viznoir/showcase/arch_structural.webp',
    alt: 'Structural FEA displacement analysis',
    label: 'Structural FEA',
  },
  {
    src: '/viznoir/showcase/dragon.webp',
    alt: 'Stanford Dragon mesh render',
    label: '3D Rendering',
  },
];
---

<section class="relative py-24">
  <div class="section-divider mb-24"></div>
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-12 fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">
        <span class="gradient-text-white">See It In Action</span>
      </h2>
      <p class="text-text-secondary max-w-lg mx-auto">
        All renders from single MCP tool calls — no post-processing.
      </p>
    </div>

    <!-- 2x3 responsive grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 fade-up">
      {images.map((img) => (
        <div class="card-hover overflow-hidden group cursor-default">
          <div class="relative aspect-video">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <span class="text-sm font-semibold text-text-primary">{img.label}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Full gallery link -->
    <div class="text-center mt-8 fade-up">
      <a href="https://kimimgo.github.io/viznoir/"
         target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent transition-colors font-mono">
        Full Gallery
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
