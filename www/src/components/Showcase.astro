---
const domains = [
  {
    src: '/viznoir/showcase/01_skull_annotated.webp',
    alt: 'CT skull volume rendering with bone and tissue layers',
    label: 'Medical',
    detail: 'CT skull volume rendering',
  },
  {
    src: '/viznoir/showcase/02_combustion_annotated.webp',
    alt: 'Combustion jet streamlines colored by temperature',
    label: 'CFD',
    detail: 'Combustion streamlines',
  },
  {
    src: '/viznoir/showcase/03_heatsink_annotated.webp',
    alt: 'Heatsink thermal gradient cross-section',
    label: 'Thermal',
    detail: 'Heatsink gradient',
  },
  {
    src: '/viznoir/showcase/04_seismic_annotated.webp',
    alt: 'Seismic wavefield depth slice',
    label: 'Geoscience',
    detail: 'Seismic wavefield',
  },
  {
    src: '/viznoir/showcase/05_drivaerml_annotated.webp',
    alt: 'DrivAerML automotive CFD pressure coefficient 8.8M cells',
    label: 'Automotive',
    detail: 'DrivAerML Cp · 8.8M cells',
  },
  {
    src: '/viznoir/showcase/06_h2o_annotated.webp',
    alt: 'H2O water molecule electron density isosurface',
    label: 'Molecular',
    detail: 'H₂O electron density',
  },
  {
    src: '/viznoir/showcase/07_aneurism_annotated.webp',
    alt: 'Cerebral aneurysm MRA vasculature volume rendering',
    label: 'Vascular',
    detail: 'Cerebral aneurysm MRA',
  },
  {
    src: '/viznoir/showcase/08_bennu_annotated.webp',
    alt: 'Bennu asteroid surface topology 196K triangles',
    label: 'Planetary',
    detail: 'Bennu · 196K triangles',
  },
  {
    src: '/viznoir/showcase/09_cantilever_annotated.webp',
    alt: 'Cantilever beam FEA stress analysis',
    label: 'Structural',
    detail: 'Cantilever FEA stress',
  },
  {
    src: '/viznoir/showcase/10_combustion_annotated.webp',
    alt: 'Combustion thermal threshold volume rendering',
    label: 'Volume',
    detail: 'Thermal threshold',
  },
];

const animations = [
  { name: 'Streamline Growth', physics: 'Lagrangian advection', preset: 'streamline_growth' },
  { name: 'Clip Sweep', physics: 'Pressure gradient cross-section', preset: 'clip_sweep' },
  { name: 'Layer Reveal', physics: 'CT density classification', preset: 'layer_reveal' },
  { name: 'Iso Sweep', physics: 'Orbital topology', preset: 'iso_sweep' },
  { name: 'Warp Oscillation', physics: 'Structural mode shape', preset: 'warp_oscillation' },
  { name: 'Light Orbit', physics: 'Oblique illumination', preset: 'light_orbit' },
  { name: 'Threshold Reveal', physics: 'Feature hierarchy', preset: 'threshold_reveal' },
];
---

<section class="relative py-24">
  <div class="section-divider mb-24"></div>
  <div class="max-w-6xl mx-auto px-6">

    <!-- 10 Domains Header -->
    <div class="text-center mb-16 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        10 DOMAINS
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">
        <span class="gradient-text-white">One Pipeline, Every Domain</span>
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto">
        Every render is a single MCP tool call &mdash; no GUI, no post-processing, no ParaView.
        VTK-native annotations rendered inside the 3D scene.
      </p>
    </div>

    <!-- Domain grid: 5 columns -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-20 fade-up">
      {domains.map((d) => (
        <div class="card-hover overflow-hidden group cursor-default">
          <div class="relative aspect-[4/3]">
            <img
              src={d.src}
              alt={d.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3">
              <span class="text-xs font-bold text-accent font-mono">{d.label}</span>
              <p class="text-[10px] text-text-secondary/60 mt-0.5">{d.detail}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Science Storytelling -->
    <div class="text-center mb-16 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        SCIENCE STORYTELLING
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">
        <span class="gradient-text-white">Physics Insights, Not Just Pixels</span>
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto mb-8">
        Extract physics, render LaTeX equations, compose cinematic story layouts.
        One pipeline, one command.
      </p>
      <div class="card-hover overflow-hidden group cursor-default">
        <img
          src="/viznoir/showcase/cavity_story.webp"
          alt="Lid-driven cavity flow: physics decomposition with LaTeX equations and multi-field cinematic renders"
          class="w-full rounded-lg transition-transform duration-500 group-hover:scale-[1.01]"
          loading="lazy"
        />
      </div>
      <p class="text-xs text-text-secondary/40 mt-4 font-mono">
        inspect_physics &rarr; cinematic_render &times; 4 &rarr; LaTeX equations &rarr; compose_assets
      </p>
    </div>

    <!-- Physics Animations -->
    <div class="text-center mb-12 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        PHYSICS ANIMATIONS
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3">
        <span class="gradient-text-white">Every Effect Has a Physical Reason</span>
      </h2>
      <p class="text-text-secondary max-w-lg mx-auto mb-8">
        Not slideshows &mdash; real VTK frame-by-frame rendering with physics-driven presets.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 fade-up">
      {animations.map((a) => (
        <div class="card-hover p-4 cursor-default">
          <div class="flex items-start gap-3">
            <div class="w-2 h-2 rounded-full bg-accent mt-1.5 shrink-0"></div>
            <div>
              <p class="text-sm font-semibold text-text-primary">{a.name}</p>
              <p class="text-xs text-text-secondary/60 mt-0.5">{a.physics}</p>
              <code class="text-[10px] text-accent/50 font-mono">{a.preset}</code>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
