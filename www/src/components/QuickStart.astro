---
import CodeBlock from './CodeBlock.astro';

const clients = ['Claude Code', 'Cursor', 'Windsurf', 'Gemini CLI'];
---

<section class="relative py-24">
  <div class="section-divider mb-24"></div>
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-14 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        QUICK START
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
        <span class="gradient-text-white">Get started in 3 steps</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 fade-up">
      <!-- Step 1: Install -->
      <div class="card-hover p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-3xl font-extrabold text-accent/15 font-mono">01</span>
          <h3 class="text-lg font-semibold text-text-primary">Install</h3>
        </div>
        <p class="text-sm text-text-secondary/70 mb-4">One-line pip install</p>
        <CodeBlock code="pip install mcp-server-viznoir" lang="bash" />
        <div class="mt-3">
          <p class="text-[11px] text-text-secondary/40 font-mono">Or with Claude Code:</p>
          <code class="text-[11px] text-accent/60 font-mono">claude install kimimgo/viznoir</code>
        </div>
      </div>

      <!-- Step 2: Configure -->
      <div class="card-hover p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-3xl font-extrabold text-accent/15 font-mono">02</span>
          <h3 class="text-lg font-semibold text-text-primary">Configure</h3>
        </div>
        <p class="text-sm text-text-secondary/70 mb-4">Add to your MCP config</p>
        <CodeBlock code={`{
  "mcpServers": {
    "viznoir": {
      "command": "mcp-server-viznoir"
    }
  }
}`} lang="json" filename=".mcp.json" />
      </div>

      <!-- Step 3: Use -->
      <div class="card-hover p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-3xl font-extrabold text-accent/15 font-mono">03</span>
          <h3 class="text-lg font-semibold text-text-primary">Use</h3>
        </div>
        <p class="text-sm text-text-secondary/70 mb-4">Prompt in natural language</p>
        <CodeBlock code={`"Analyze cavity.foam, then compose
a story with LaTeX equations"`} lang="text" />
      </div>
    </div>

    <!-- Client logos -->
    <div class="mt-12 text-center fade-up">
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <span class="text-xs text-text-secondary/40 font-mono">Compatible with</span>
        {clients.map((name) => (
          <span class="px-3 py-1.5 rounded-lg bg-secondary border border-border text-xs font-mono text-text-secondary/60 hover:text-text-secondary hover:border-accent/20 transition-all">
            {name}
          </span>
        ))}
      </div>
    </div>

  </div>
</section>
